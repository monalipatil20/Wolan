# Wolan Logistics Backend - Environment Variables Template
# Copy this file to .env and fill in the values

# ============== REQUIRED ==============

# Environment (development, production, test)
NODE_ENV=development

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/wolan

# JWT Secret (min 32 characters)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# ============== SERVER ==============

# Server Port
PORT=5000

# ============== SECURITY ==============

# JWT Expiration
JWT_EXPIRE=7d

# JWT Cookie Expiration (days)
JWT_COOKIE_EXPIRE=7

# Rate Limiting (milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Rate Limit (max requests per window)
RATE_LIMIT_MAX_REQUESTS=100

# ============== CORS ==============

# Client Origin (comma-separated for multiple)
CLIENT_ORIGIN=http://localhost:3000

# Socket.io CORS Origin
SOCKET_CORS_ORIGIN=http://localhost:3000

# ============== FILE UPLOAD ==============

# Maximum File Size (bytes)
MAX_FILE_SIZE=5242880

# Upload Directory
UPLOAD_PATH=./uploads

# ============== OPTIONAL (Production) ==============

# Log Directory
# LOG_DIR=./logs

# Database Name (if using Atlas)
# DB_NAME=wolan
